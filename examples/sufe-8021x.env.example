# Copy this file to /etc/sufe-8021x/sufe-8021x.env.
# Keep the real file root-readable only:
#   sudo chmod 600 /etc/sufe-8021x/sufe-8021x.env

SUFE_IFACE=enp1s0
SUFE_USERNAME=your-card-number@cmcc
SUFE_PASSWORD=your-password

# Authorized MAC address for the wired account.
SUFE_MAC=00:11:22:33:44:55

# Campus network values observed on one SUFE wired segment.
# Adjust if your lease gives a different gateway/DNS pair.
SUFE_GATEWAY=10.64.0.1
SUFE_DNS1=211.136.150.66
SUFE_DNS2=211.136.112.50
SUFE_CAMPUS_METRIC=50

# The authenticator writes this after EAP Success. DHCP waits for it.
SUFE_AUTH_STATE=/run/sufe-8021x-authenticated
SUFE_AUTH_WAIT_SECONDS=75

# Optional management fallback route.
# Leave blank if you do not use a separate management interface.
SUFE_MGMT_IFACE=enp2s0
SUFE_MGMT_GATEWAY=192.168.137.1
SUFE_MGMT_METRIC=500
